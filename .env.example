# Copy values into your shell profile or local environment manager.
# ACA does not require committing any real .env file.

# Primary provider used by current ACA workflows.
NANOGPT_API_KEY=

# Optional provider keys for direct OpenAI/Anthropic driver experiments.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional NanoGPT-compatible override used by benchmark/debug scripts.
NANOGPT_URL=

# Optional verbose MCP/server diagnostics.
ACA_DEBUG=0
